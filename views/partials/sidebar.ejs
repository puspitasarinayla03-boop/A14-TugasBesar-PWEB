<%# Sidebar Partial %>
<style>
  .sidebar {
    width: 260px;
    background-color: #ffffff;
    border-right: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: sticky;
    top: 0;
    flex-shrink: 0;
  }
  .sidebar-brand {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #ffffff;
  }
  .sidebar-logo {
    height: 45px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }
  .sidebar-menu {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 0;
  }
  .sidebar-group h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
    margin: 1rem 1.5rem 0.5rem 1.5rem;
    font-weight: 600;
  }
  .sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sidebar li a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    color: #475569;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .sidebar li a svg {
    color: #94a3b8;
    transition: color 0.2s ease;
  }
  .sidebar li a:hover {
    background-color: #f8fafc;
    color: var(--fti-blue);
  }
  .sidebar li a:hover svg {
    color: var(--fti-blue);
  }
  .sidebar li a[aria-current="page"] {
    background-color: #f1f5f9;
    color: var(--fti-blue-dark);
    font-weight: 600;
    border-right: 3px solid var(--fti-blue);
  }
  .sidebar li a[aria-current="page"] svg {
    color: var(--fti-blue-dark);
  }
  .sidebar-footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid #e2e8f0;
    background: #ffffff;
  }
  .user-profile {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .user-avatar {
    width: 36px;
    height: 36px;
    background-color: #e2e8f0;
    color: #475569;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
  }
  .user-details p {
    margin: 0;
    line-height: 1.3;
  }
  .user-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1e293b;
  }
  .user-email {
    font-size: 0.75rem;
    color: #64748b;
    max-width: 140px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .btn-logout {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem;
    background: transparent;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    color: #64748b;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .btn-logout:hover {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #ef4444;
  }
</style>

<aside class="sidebar" id="main-sidebar">
  <nav style="display: flex; flex-direction: column; height: 100%;">
    
    <header class="sidebar-brand">
      <img src="/images/fti-logo.png" alt="Logo FTI" class="sidebar-logo" onerror="this.style.display='none'">
    </header>

    <section class="sidebar-menu">
      <div class="sidebar-group">
        <h3>Menu Utama</h3>
        <ul>
          <li>
            <a href="/dashboard" <%= currentPage === 'dashboard' ? 'aria-current="page"' : '' %>>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
              <span>Dashboard</span>
            </a>
          </li>
        </ul>
      </div>

      <% if (user.role === 'admin') { %>
      <div class="sidebar-group" style="margin-top: 1rem;">
        <h3>Administrasi</h3>
        <ul>
          <li>
            <a href="/admin/users" <%= currentPage === 'admin-users' ? 'aria-current="page"' : '' %>>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Kelola Users</span>
            </a>
          </li>
        </ul>
      </div>
      <% } %>
    </section>

    <footer class="sidebar-footer">
      <div class="user-profile">
        <div class="user-avatar"><%= user.name.charAt(0) %></div>
        <div class="user-details">
          <p class="user-name"><%= user.name %></p>
          <p class="user-email"><%= user.email %></p>
        </div>
      </div>
      <button id="logoutBtn" type="button" class="btn-logout">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
        Keluar
      </button>
    </footer>

  </nav>
</aside>
