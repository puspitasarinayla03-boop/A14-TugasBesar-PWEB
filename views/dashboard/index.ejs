<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — FTI Project</title>
  <!-- Basecoat UI CSS (Lokal) -->
  <link rel="stylesheet" href="/basecoat/basecoat.min.css" />
  <script src="/basecoat/js/basecoat.min.js" defer></script>
  <script src="/basecoat/js/sidebar.min.js" defer></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    
    :root {
      --bc-font-family: 'Inter', system-ui, -apple-system, sans-serif;
      --fti-blue: #70869e;
      --fti-blue-dark: #5b6f85;
      --bc-color-primary: var(--fti-blue);
      --bc-border-radius: 8px;
    }

    body {
      margin: 0;
      font-family: var(--bc-font-family);
      background-color: #f4f6f8;
      color: #334155;
      display: flex;
      min-height: 100vh;
    }

    /* Layout Dasar */
    main {
      flex: 1;
      padding: 2rem;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }

    /* Header & Typography */
    .page-header {
      margin-bottom: 2rem;
    }
    .page-title {
      font-size: 1.75rem;
      font-weight: 700;
      color: #1e293b;
      margin: 0 0 0.5rem 0;
    }
    .text-muted {
      color: #64748b;
      font-size: 0.95rem;
      margin: 0;
    }

    /* Grid Layout untuk Cards */
    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    /* Styling Basecoat Components agar lebih elegan */
    .card {
      background: #ffffff;
      border: none;
      border-radius: 12px;
      box-shadow: 0 10px 40px -10px rgba(112, 134, 158, 0.15);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
    }
    .card header h2 {
      font-size: 1rem;
      font-weight: 600;
      color: #475569;
      margin: 0 0 1rem 0;
      border-bottom: 1px solid #f1f5f9;
      padding-bottom: 0.5rem;
    }
    .card section {
      flex: 1;
    }
    
    /* Utilities Tambahan */
    .flex-between {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
    }
    .text-xl { font-size: 1.25rem; font-weight: 700; color: #1e293b; margin: 0 0 0.25rem 0;}
    .text-sm { font-size: 0.875rem; color: #64748b; margin: 0; }
    
    /* Custom Badges */
    .badge-green { background: #dcfce7; color: #166534; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
    .badge-red { background: #fee2e2; color: #991b1b; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
    .badge-outline { border: 1px solid var(--fti-blue); color: var(--fti-blue); padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.75rem; display: inline-block; margin-top: 1rem;}

    .btn-dark {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 1.2rem;
      background-color: var(--fti-blue);
      color: white;
      font-size: 0.9rem;
      font-weight: 600;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      transition: background-color 0.2s;
    }
    .btn-dark:hover { background-color: var(--fti-blue-dark); }
  </style>
</head>
<body>

  <!-- Sidebar -->
  <%- include('../partials/sidebar', { currentPage: 'dashboard' }) %>

  <main>
    <div class="page-header">
      <h1 class="page-title">Dashboard</h1>
      <p class="text-muted">Selamat datang, <strong><%= user.name %></strong>!</p>
    </div>

    <!-- Alert info role -->
    <div class="alert" style="margin-bottom: 2rem; background: #e2e8f0; color: #334155; border: none; border-radius: 8px; padding: 1rem; display: flex; gap: 1rem; align-items: center;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      <span style="font-size: 0.95rem;">
        Anda login sebagai <strong><%= user.role %></strong>.
        <% if (user.role === 'admin') { %>Anda memiliki akses penuh termasuk manajemen user.
        <% } else { %>Anda memiliki akses sebagai pengguna reguler.<% } %>
      </span>
    </div>

    <!-- Stats cards -->
    <div class="dashboard-grid">
      <!-- Profil -->
      <div class="card">
        <header><h2>Akun Saya</h2></header>
        <section>
          <p class="text-xl"><%= user.name %></p>
          <p class="text-sm" style="word-break: break-all;"><%= user.email %></p>
        </section>
        <footer><span class="badge-outline">Role: <%= user.role %></span></footer>
      </div>

      <!-- ACL Status -->
      <div class="card">
        <header><h2>Status Akses (ACL)</h2></header>
        <section>
          <div class="flex-between">
            <span class="text-sm">Akses Dashboard</span>
            <span class="badge-green">✓ Diizinkan</span>
          </div>
          <div class="flex-between">
            <span class="text-sm">Kelola Users</span>
            <% if (user.role === 'admin') { %>
              <span class="badge-green">✓ Diizinkan</span>
            <% } else { %>
              <span class="badge-red">✗ Ditolak</span>
            <% } %>
          </div>
          <div class="flex-between">
            <span class="text-sm">Hapus User</span>
            <% if (user.role === 'admin') { %>
              <span class="badge-green">✓ Diizinkan</span>
            <% } else { %>
              <span class="badge-red">✗ Ditolak</span>
            <% } %>
          </div>
        </section>
      </div>

      <!-- JWT -->
      <div class="card">
        <header><h2>Sistem Keamanan</h2></header>
        <section>
          <p class="text-sm" style="color: #1e293b; font-weight: 500; margin-bottom: 0.25rem;">JWT Session Active</p>
          <p class="text-sm">Token dikunci via HttpOnly Cookie. Sangat aman dari serangan XSS.</p>
        </section>
        <footer style="margin-top: 1rem;"><span class="badge-green">● Secured</span></footer>
      </div>
    </div>

    <!-- Admin panel link -->
    <% if (user.role === 'admin') { %>
    <div class="card" style="margin-bottom: 2rem;">
      <header>
        <h2 style="margin-bottom: 0;">Panel Administrasi</h2>
      </header>
      <section>
        <p class="text-sm" style="margin-bottom: 1.5rem;">Fitur eksklusif Administrator. Anda dapat mengelola semua akun pengguna, mengubah status aktif, hingga menghapus user dari sistem.</p>
        <a href="/admin/users" class="btn-dark">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Kelola Users Sekarang
        </a>
      </section>
    </div>
    <% } %>
  </main>

  <script>
    document.getElementById('logoutBtn').addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' }).catch(() => {});
      window.location.href = '/login';
    });
  </script>
</body>
</html>
