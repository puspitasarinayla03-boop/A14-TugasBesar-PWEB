<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — FTI Project</title>
  <link rel="stylesheet" href="/basecoat/basecoat.min.css" />
  <script src="/basecoat/js/basecoat.min.js" defer></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    :root { --fti-blue: #70869e; --fti-blue-dark: #5b6f85; }
    body { margin:0; font-family:'Inter',system-ui,sans-serif; background:#f4f6f8; color:#334155; display:flex; min-height:100vh; }
    main { flex:1; padding:2rem; max-width:1200px; margin:0 auto; width:100%; box-sizing:border-box; }
    .page-header { margin-bottom:2rem; }
    .page-title  { font-size:1.75rem; font-weight:700; color:#1e293b; margin:0 0 0.4rem; }
    .text-muted  { color:#64748b; font-size:0.95rem; margin:0; }

    .stats-grid {
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(210px,1fr));
      gap:1.25rem;
      margin-bottom:2rem;
    }
    .stat-card {
      background:#fff; border-radius:12px;
      box-shadow:0 4px 20px -4px rgba(112,134,158,.15);
      padding:1.5rem; display:flex; align-items:flex-start; gap:1rem;
    }
    .stat-icon {
      width:44px; height:44px; border-radius:10px;
      display:flex; align-items:center; justify-content:center; flex-shrink:0;
    }
    .icon-blue   { background:#dbeafe; color:#1d4ed8; }
    .icon-green  { background:#dcfce7; color:#166534; }
    .icon-amber  { background:#fef3c7; color:#92400e; }
    .icon-slate  { background:#f1f5f9; color:#475569; }
    .stat-value  { font-size:2rem; font-weight:700; color:#1e293b; margin:0 0 .15rem; line-height:1; }
    .stat-label  { font-size:.85rem; color:#64748b; margin:0; }

    .card {
      background:#fff; border-radius:12px;
      box-shadow:0 4px 20px -4px rgba(112,134,158,.15);
      padding:1.5rem; margin-bottom:1.5rem;
    }
    .card-title {
      font-size:1rem; font-weight:600; color:#1e293b;
      margin:0 0 1.25rem; padding-bottom:.75rem; border-bottom:1px solid #f1f5f9;
    }
    .quick-links { display:grid; grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); gap:1rem; }
    .quick-link {
      display:flex; align-items:center; gap:.75rem;
      padding:1rem 1.25rem; background:#f8fafc;
      border:1px solid #e2e8f0; border-radius:8px;
      text-decoration:none; color:#334155;
      font-weight:500; font-size:.9rem; transition:all .2s;
    }
    .quick-link svg   { color:var(--fti-blue); flex-shrink:0; }
    .quick-link:hover { background:#f1f5f9; border-color:var(--fti-blue); color:var(--fti-blue-dark); }

    .info-row { display:flex; gap:2.5rem; flex-wrap:wrap; }
    .info-item label { font-size:.75rem; color:#94a3b8; text-transform:uppercase; letter-spacing:.05em; margin:0 0 .25rem; display:block; }
    .info-item p     { margin:0; font-weight:600; color:#1e293b; }
    .badge-active    { display:inline-block; background:#dcfce7; color:#166534; padding:.2rem .6rem; border-radius:4px; font-size:.8rem; font-weight:600; }
  </style>
</head>
<body>
  <%- include('../partials/sidebar', { currentPage: 'dashboard', user: user }) %>

  <main>
    <div class="page-header">
      <h1 class="page-title">Dashboard</h1>
      <p class="text-muted">Selamat datang, <strong><%= user.name %></strong>!</p>
    </div>

    <!-- Statistik Project -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon icon-blue">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </div>
        <div>
          <p class="stat-value"><%= stats.total || 0 %></p>
          <p class="stat-label">Total Project</p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon icon-green">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <p class="stat-value"><%= stats.aktif || 0 %></p>
          <p class="stat-label">Project Aktif</p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon icon-amber">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
        </div>
        <div>
          <p class="stat-value"><%= stats.pending || 0 %></p>
          <p class="stat-label">Project Pending</p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon icon-slate">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <p class="stat-value"><%= stats.selesai || 0 %></p>
          <p class="stat-label">Project Selesai</p>
        </div>
      </div>
    </div>

    <!-- Akses Cepat -->
    <div class="card">
      <h2 class="card-title">Akses Cepat</h2>
      <div class="quick-links">
        <a href="/projects" class="quick-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          Lihat Semua Project
        </a>
        <a href="/projects/create" class="quick-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
          Tambah Project Baru
        </a>
      </div>
    </div>

    <!-- Info Sesi -->
    <div class="card">
      <h2 class="card-title">Informasi Sesi</h2>
      <div class="info-row">
        <div class="info-item"><label>Nama</label><p><%= user.name %></p></div>
        <div class="info-item"><label>Email</label><p><%= user.email %></p></div>
        <div class="info-item"><label>Status</label><span class="badge-active">● Aktif</span></div>
      </div>
    </div>
  </main>
</body>
</html>
