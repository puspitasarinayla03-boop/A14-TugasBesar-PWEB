<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> — FTI Project</title>
  <link rel="stylesheet" href="/basecoat/basecoat.min.css"/>
  <script src="/basecoat/js/basecoat.min.js" defer></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    :root{--fti-blue:#70869e;--fti-blue-dark:#5b6f85;}
    body{margin:0;font-family:'Inter',system-ui,sans-serif;background:#f4f6f8;color:#334155;display:flex;min-height:100vh;}
    main{flex:1;padding:2rem;max-width:1200px;margin:0 auto;width:100%;box-sizing:border-box;}
    .page-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;}
    .page-title{font-size:1.75rem;font-weight:700;color:#1e293b;margin:0 0 .25rem;}
    .text-muted{color:#64748b;font-size:.9rem;margin:0;}
    .btn-primary{display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.25rem;background:var(--fti-blue);color:#fff;font-size:.9rem;font-weight:600;border:none;border-radius:8px;text-decoration:none;cursor:pointer;transition:background .2s;font-family:inherit;}
    .btn-primary:hover{background:var(--fti-blue-dark);}
    .card{background:#fff;border-radius:12px;box-shadow:0 4px 20px -4px rgba(112,134,158,.15);overflow:hidden;}
    table{width:100%;border-collapse:collapse;}
    thead th{text-align:left;padding:.85rem 1.25rem;font-size:.78rem;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.05em;border-bottom:1px solid #f1f5f9;background:#fafafa;}
    tbody td{padding:.9rem 1.25rem;font-size:.9rem;border-bottom:1px solid #f8fafc;vertical-align:middle;}
    tbody tr:last-child td{border-bottom:none;}
    tbody tr:hover{background:#fafafa;}
    .badge{display:inline-block;padding:.25rem .65rem;border-radius:20px;font-size:.75rem;font-weight:600;}
    .badge-aktif{background:#dcfce7;color:#166534;}
    .badge-pending{background:#fef3c7;color:#92400e;}
    .badge-selesai{background:#dbeafe;color:#1e40af;}
    .actions{display:flex;gap:.5rem;}
    .btn-sm{display:inline-flex;align-items:center;gap:.3rem;padding:.35rem .75rem;border-radius:6px;font-size:.8rem;font-weight:500;text-decoration:none;border:none;cursor:pointer;transition:all .2s;font-family:inherit;}
    .btn-view{background:#f1f5f9;color:#475569;}.btn-view:hover{background:#e2e8f0;}
    .btn-edit{background:#fef3c7;color:#92400e;}.btn-edit:hover{background:#fde68a;}
    .btn-delete{background:#fee2e2;color:#991b1b;}.btn-delete:hover{background:#fca5a5;}
    .empty-state{text-align:center;padding:4rem 2rem;color:#94a3b8;}
    .empty-state p{margin:.75rem 0 1.5rem;}
    .loading{text-align:center;padding:3rem;color:#94a3b8;font-size:.95rem;}
    .toast{position:fixed;top:1.25rem;right:1.25rem;padding:.85rem 1.25rem;border-radius:10px;font-size:.875rem;font-weight:500;z-index:9999;display:none;align-items:center;gap:.6rem;box-shadow:0 8px 24px -4px rgba(0,0,0,.15);}
    .toast.show{display:flex;}
    .toast-success{background:#dcfce7;color:#166534;}
    .toast-error{background:#fee2e2;color:#991b1b;}
  </style>
</head>
<body>
  <%- include('../partials/sidebar', { currentPage: 'projects', user: user }) %>

  <div id="toast" class="toast" role="alert"></div>

  <main>
    <div class="page-header">
      <div>
        <h1 class="page-title">Manajemen Project</h1>
        <p class="text-muted">Daftar semua project yang terdaftar</p>
      </div>
      <a href="/projects/create" class="btn-primary" id="btn-tambah">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
        Tambah Project
      </a>
    </div>

    <div class="card">
      <div id="table-container">
        <div class="loading">Memuat data...</div>
      </div>
    </div>
  </main>

  <script>
    const container = document.getElementById('table-container');
    const toast     = document.getElementById('toast');

    function showToast(msg, type = 'success') {
      toast.className = `toast toast-${type} show`;
      toast.innerHTML = (type === 'success'
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>'
      ) + `<span>${msg}</span>`;
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    function badgeHtml(status) {
      return `<span class="badge badge-${status}">${status.charAt(0).toUpperCase() + status.slice(1)}</span>`;
    }

    function fmtDate(d) {
      if (!d) return '—';
      return new Date(d).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function renderTable(projects) {
      if (!projects.length) {
        container.innerHTML = `
          <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.3"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            <p>Belum ada project. Tambahkan yang pertama!</p>
            <a href="/projects/create" class="btn-primary">Tambah Project</a>
          </div>`;
        return;
      }

      const rows = projects.map((p, i) => `
        <tr>
          <td style="color:#94a3b8">${i + 1}</td>
          <td style="font-weight:500;color:#1e293b">${p.name}</td>
          <td>${badgeHtml(p.status)}</td>
          <td>${fmtDate(p.start_date)}</td>
          <td>${fmtDate(p.end_date)}</td>
          <td>
            <div class="actions">
              <a href="/projects/${p.id}" class="btn-sm btn-view">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Lihat
              </a>
              <a href="/projects/${p.id}/edit" class="btn-sm btn-edit">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit
              </a>
              <button class="btn-sm btn-delete" onclick="deleteProject(${p.id}, '${p.name.replace(/'/g, "\\'")}')">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                Hapus
              </button>
            </div>
          </td>
        </tr>`).join('');

      container.innerHTML = `
        <table>
          <thead>
            <tr>
              <th style="width:40px">#</th>
              <th>Nama Project</th>
              <th>Status</th>
              <th>Tanggal Mulai</th>
              <th>Tanggal Selesai</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>`;
    }

    async function loadProjects() {
      try {
        const res  = await fetch('/api/projects');
        const data = await res.json();
        if (data.success) renderTable(data.data);
        else container.innerHTML = `<div class="empty-state"><p>Gagal memuat data: ${data.message}</p></div>`;
      } catch {
        container.innerHTML = `<div class="empty-state"><p>Tidak dapat terhubung ke server.</p></div>`;
      }
    }

    async function deleteProject(id, name) {
      if (!confirm(`Hapus project "${name}"?`)) return;
      try {
        const res  = await fetch(`/api/projects/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          showToast(data.message, 'success');
          loadProjects();
        } else {
          showToast(data.message, 'error');
        }
      } catch {
        showToast('Gagal menghapus project.', 'error');
      }
    }

    loadProjects();
  </script>
</body>
</html>
