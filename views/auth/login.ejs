<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — FTI Project</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Basecoat UI CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/basecoat-css@0.3.11/dist/basecoat.cdn.min.css" />
  <!-- Basecoat UI JS -->
  <script src="https://cdn.jsdelivr.net/npm/basecoat-css@0.3.11/dist/js/basecoat.min.js" defer></script>
</head>
<body class="h-full bg-background text-foreground flex items-center justify-center p-4">

  <div class="w-full max-w-sm">

    <!-- Brand -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center size-14 rounded-2xl bg-primary text-primary-foreground mb-4 shadow-lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect width="7" height="9" x="3" y="3" rx="1"/>
          <rect width="7" height="5" x="14" y="3" rx="1"/>
          <rect width="7" height="9" x="14" y="12" rx="1"/>
          <rect width="7" height="5" x="3" y="16" rx="1"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold tracking-tight">FTI Project</h1>
    </div>

    <!-- Card Login -->
    <div class="card w-full">
      <header>
        <h2>Masuk ke Akun</h2>
        <p>Masukkan email dan password Anda</p>
      </header>

      <section>
        <!-- Alert error dari server-side -->
        <% if (error) { %>
        <div class="alert mb-4" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
          <span><%= error %></span>
        </div>
        <% } %>

        <!-- Alert dinamis dari JS fetch -->
        <div id="alert-box" class="alert mb-4 hidden" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
          <span id="alert-msg"></span>
        </div>

        <form id="loginForm" class="form grid gap-5" novalidate>
          <div class="grid gap-2">
            <label for="email" class="label">Email</label>
            <input class="input" type="email" id="email" name="email" placeholder="admin@ftiproject.com" autocomplete="email" required />
          </div>

          <div class="grid gap-2">
            <div class="flex items-center justify-between">
              <label for="password" class="label">Password</label>
            </div>
            <div class="relative">
              <input class="input pr-10" type="password" id="password" name="password" placeholder="••••••••" autocomplete="current-password" required />
              <button type="button" id="togglePwd"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors"
                aria-label="Toggle password visibility">
                <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <button type="submit" id="loginBtn" class="btn w-full">
            <svg id="btnSpinner" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden animate-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
            <span id="btnText">Masuk</span>
          </button>
        </form>
      </section>

      <footer class="flex flex-col items-center gap-2">
        <p class="text-sm text-muted-foreground">
          Belum punya akun?
          <a href="/register" class="text-primary underline-offset-4 hover:underline font-medium">Daftar Sekarang</a>
        </p>
      </footer>
    </div>

  </div>

  <script>
    // Toggle show/hide password
    const toggleBtn = document.getElementById('togglePwd');
    const pwdInput  = document.getElementById('password');
    let   visible   = false;
    toggleBtn.addEventListener('click', () => {
      visible = !visible;
      pwdInput.type = visible ? 'text' : 'password';
      toggleBtn.querySelector('svg').innerHTML = visible
        ? '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/>'
        : '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>';
    });

    // Tampilkan alert
    function showAlert(msg, isSuccess = false) {
      const box  = document.getElementById('alert-box');
      const text = document.getElementById('alert-msg');
      text.textContent = msg;
      box.classList.remove('hidden');
      box.style.setProperty('--tw-bg-opacity', '1');
      if (isSuccess) box.classList.add('!border-green-500', '!bg-green-50');
      else           box.classList.remove('!border-green-500', '!bg-green-50');
    }

    // Handle form submit via fetch
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn     = document.getElementById('loginBtn');
      const spinner = document.getElementById('btnSpinner');
      const btnText = document.getElementById('btnText');

      btn.disabled = true;
      spinner.classList.remove('hidden');
      btnText.textContent = 'Memproses...';

      try {
        const res  = await fetch('/api/auth/login', {
          method : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body   : JSON.stringify({
            email   : document.getElementById('email').value.trim(),
            password: document.getElementById('password').value,
          }),
        });
        const data = await res.json();

        if (res.ok) {
          showAlert('Login berhasil! Mengalihkan...', true);
          setTimeout(() => { window.location.href = '/dashboard'; }, 900);
        } else {
          showAlert(data.message || 'Login gagal. Periksa kembali email dan password.');
          btn.disabled = false;
          spinner.classList.add('hidden');
          btnText.textContent = 'Masuk';
        }
      } catch {
        showAlert('Tidak dapat terhubung ke server. Coba lagi.');
        btn.disabled = false;
        spinner.classList.add('hidden');
        btnText.textContent = 'Masuk';
      }
    });
  </script>
</body>
</html>
