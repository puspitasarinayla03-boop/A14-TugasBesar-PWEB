<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — FTI Project</title>
  <link rel="stylesheet" href="/basecoat/basecoat.min.css" />
  <script src="/basecoat/js/basecoat.min.js" defer></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

    :root {
      --bc-font-family: 'Inter', system-ui, -apple-system, sans-serif;
      --fti-blue:      #70869e;
      --fti-blue-dark: #5b6f85;
    }

    body {
      display:         flex;
      flex-direction:  column;
      align-items:     center;
      justify-content: center;
      min-height:      100vh;
      margin:          0;
      font-family:     var(--bc-font-family);
      background-color: #f4f6f8;
      color:           #334155;
    }

    main {
      width:         100%;
      max-width:     420px;
      padding:       2.5rem 2rem;
      background:    #ffffff;
      border-radius: 12px;
      box-shadow:    0 10px 40px -10px rgba(112, 134, 158, 0.2);
    }

    .text-center { text-align: center; }
    .mb-4        { margin-bottom: 1rem; }
    .mb-6        { margin-bottom: 1.5rem; }
    .mt-6        { margin-top: 1.5rem; }

    label {
      display:       block;
      font-size:     0.875rem;
      font-weight:   500;
      color:         #475569;
      margin-bottom: 0.25rem;
    }

    .input {
      display:       block;
      width:         100%;
      padding:       0.6rem 0;
      border:        none;
      border-bottom: 2px solid #e2e8f0;
      background:    transparent;
      font-family:   inherit;
      font-size:     1rem;
      color:         #334155;
      transition:    border-color 0.3s ease;
      border-radius: 0;
      box-sizing:    border-box;
    }

    .input:focus {
      outline:            none;
      border-bottom-color: var(--fti-blue);
    }

    .input::placeholder { color: #cbd5e1; }

    /* Alert error dari server */
    .error-box {
      display:       flex;
      align-items:   center;
      gap:           0.5rem;
      background:    #fee2e2;
      color:         #991b1b;
      border-radius: 8px;
      padding:       0.75rem 1rem;
      font-size:     0.875rem;
      margin-bottom: 1rem;
    }

    .btn-login {
      display:         inline-flex;
      align-items:     center;
      justify-content: center;
      width:           100%;
      padding:         0.8rem 1rem;
      background-color: var(--fti-blue);
      color:           white;
      font-size:       1rem;
      font-weight:     600;
      border:          none;
      border-radius:   8px;
      cursor:          pointer;
      transition:      background-color 0.2s;
    }

    .btn-login:hover { background-color: var(--fti-blue-dark); }
  </style>
</head>

<body>
  <main>
    <div class="text-center mb-6">
      <img src="/images/fti-logo.png" alt="Logo FTI Unand"
        style="height:110px; width:auto; max-width:100%; object-fit:contain; margin:0 auto 1.5rem auto; display:block;"
        onerror="this.style.display='none'">
      <h1 style="font-size:1.5rem; font-weight:600; margin:0; color:#1e293b;">FTI Project</h1>
    </div>

    <% if (error) { %>
    <div class="error-box" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" x2="12" y1="8" y2="12"/>
        <line x1="12" x2="12.01" y1="16" y2="16"/>
      </svg>
      <span><%= error %></span>
    </div>
    <% } %>

    <form method="POST" action="/auth/login" novalidate>
      <div class="mb-4">
        <label for="email">Email</label>
        <input class="input" type="email" id="email" name="email"
          placeholder="Masukkan email Anda" autocomplete="email" required />
      </div>

      <div class="mb-4">
        <label for="password">Password</label>
        <input class="input" type="password" id="password" name="password"
          placeholder="Masukkan password Anda" autocomplete="current-password" required />
      </div>

      <button type="submit" id="loginBtn" class="btn-login mt-6">Masuk</button>
    </form>
  </main>
</body>

</html>